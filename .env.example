# ==============================================
# Sabiencia EAD — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores antes de iniciar o servidor.
# ==============================================

# ---- Supabase (obrigatório para modo produção) ----
# URL do projeto Supabase. Encontrada em: Project Settings > API > Project URL
VITE_SUPABASE_URL=https://<seu-projeto>.supabase.co

# Chave anônima pública do Supabase. Encontrada em: Project Settings > API > anon public
VITE_SUPABASE_ANON_KEY=<chave-anon-aqui>

# ---- Segurança de sessão (obrigatório) ----
# Segredo usado para assinar tokens de sessão com HMAC-SHA256.
# Gere um valor seguro com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ATENÇÃO: Nunca use o mesmo valor em produção e desenvolvimento.
VITE_AUTH_SECRET=<segredo-de-32-bytes-em-hex>

# ---- Modo demonstração (opcional) ----
# Define se o login demo (sem Supabase) está habilitado.
# Use "true" apenas em desenvolvimento local. Em produção, omita ou defina como "false".
# VITE_DEMO_MODE=false
